{
  "manifest_version": 3,
  "name": "Doodler",
  "description": "Turns X/Twitter into a sketchy paper UI with doodle icons and wobbly borders.",
  "version": "0.1.0",
  "permissions": ["storage"],
  "icons": {
    "16": "assets/icons-generated/icon-16.png",
    "32": "assets/icons-generated/icon-32.png",
    "48": "assets/icons-generated/icon-48.png",
    "128": "assets/icons-generated/icon-128.png"
  },
  "action": {
    "default_title": "Doodler",
    "default_icon": {
      "16": "assets/icons-generated/icon-16.png",
      "32": "assets/icons-generated/icon-32.png",
      "48": "assets/icons-generated/icon-48.png",
      "128": "assets/icons-generated/icon-128.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "css": ["src/content.css"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/icons/*.svg"],
      "matches": ["https://x.com/*", "https://twitter.com/*"]
    }
  ]
}
